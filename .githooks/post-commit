#!/bin/sh
# Auto-update VERSION file after every commit.
# Format: {GoldenImageVersion}+{short-hash}  (e.g. 2.3.1+c8b0bb9)
#
# The VERSION file in the working tree always reflects the CURRENT commit.
# It gets included in the next commit automatically.
#
# Install: git config core.hooksPath .githooks

VERSION_NUM=$(grep "GoldenImageVersion" lib/Config.ps1 2>/dev/null | grep -oP "'\K[^']+")
[ -z "$VERSION_NUM" ] && VERSION_NUM="unknown"

COMMIT_HASH=$(git rev-parse --short HEAD)
echo "${VERSION_NUM}+${COMMIT_HASH}" > VERSION
