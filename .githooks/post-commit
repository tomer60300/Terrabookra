#!/bin/sh
# Auto-update version stamp after every commit.
# Updates two locations:
#   1. VERSION file          (for humans / USB transfer tracking)
#   2. $Script:BootstrapVersion in Bootstrap-GitLabRunner.ps1 (for runtime logging)
#
# Install: git config core.hooksPath .githooks

VERSION_NUM=$(grep "GoldenImageVersion" lib/Config.ps1 2>/dev/null | grep -oP "'\K[^']+")
[ -z "$VERSION_NUM" ] && VERSION_NUM="unknown"

COMMIT_HASH=$(git rev-parse --short HEAD)
STAMP="${VERSION_NUM}+${COMMIT_HASH}"

# 1. Update VERSION file
echo "$STAMP" > VERSION

# 2. Update embedded version in Bootstrap-GitLabRunner.ps1
if [ -f Bootstrap-GitLabRunner.ps1 ]; then
    sed -i "s/^\$Script:BootstrapVersion.*=.*/\$Script:BootstrapVersion   = '${STAMP}'/" Bootstrap-GitLabRunner.ps1
fi
