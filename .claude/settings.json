{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command \"& ([System.IO.Path]::Combine($env:CLAUDE_PROJECT_DIR, '.claude', 'hooks', 'verify-ps-hook.ps1'))\""
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "superpowers@superpowers-marketplace": true,
    "packer-builders@hashicorp": true,
    "terraform-code-generation@hashicorp": true,
    "terraform-module-generation@hashicorp": true
  }
}
